{
  "name": "error2prompt",
  "version": "0.1.1",
  "description": "Turn runtime errors into AI-ready prompts.",
  "type": "module",
  "license": "MIT",
  "author": "",
  "bin": {
    "error2prompt": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "dependencies": {
    "cac": "^6.7.14",
    "clipboardy": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "ai",
    "debugging",
    "errors",
    "nextjs",
    "react",
    "vite",
    "prompt"
  ]
}